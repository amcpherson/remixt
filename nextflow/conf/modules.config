/*
 * Module-level ext.args configuration.
 *
 * Maps params.* values to CLI arguments for each process.
 * This replaces the config YAML file that was previously passed to all processes.
 */

process {

    withName: 'create_chromosome_seqdata' {
        ext.args = {[
            "--max_fragment_length ${params.bam_max_fragment_length}",
            "--max_soft_clipped ${params.bam_max_soft_clipped}",
            params.bam_check_proper_pair ? "--check_proper_pair" : "--no_check_proper_pair",
        ].join(' ')}
    }


    withName: 'infer_snp_genotype_from_normal' {
        ext.args = {[
            "--sequencing_base_call_error ${params.sequencing_base_call_error}",
            "--het_snp_call_threshold ${params.het_snp_call_threshold}",
        ].join(' ')}
    }

    withName: 'infer_snp_genotype_from_tumour' {
        ext.args = {[
            "--sequencing_base_call_error ${params.sequencing_base_call_error}",
            "--homozygous_p_value_threshold ${params.homozygous_p_value_threshold}",
        ].join(' ')}
    }

    withName: 'infer_haps' {
        ext.args = {[
            "--ensembl_genome_version ${params.ensembl_genome_version}",
            params.chr_name_prefix ? "--chr_name_prefix ${params.chr_name_prefix}" : "",
            params.is_female ? "--is_female" : "--is_male",
            "--shapeit_num_samples ${params.shapeit_num_samples}",
            "--shapeit_confidence_threshold ${params.shapeit_confidence_threshold}",
        ].findAll { it }.join(' ')}
    }

    withName: 'calc_fragment_stats' {
        ext.args = {[
            params.filter_duplicates ? "--filter_duplicates" : "--no_filter_duplicates",
            "--map_qual_threshold ${params.map_qual_threshold}",
        ].join(' ')}
    }

    withName: 'sample_gc' {
        ext.args = {[
            "--sample_gc_num_positions ${params.sample_gc_num_positions}",
            "--gc_position_offset ${params.gc_position_offset}",
            params.filter_duplicates ? "--filter_duplicates" : "--no_filter_duplicates",
            "--map_qual_threshold ${params.map_qual_threshold}",
            params.chromosomes ? "--chromosomes ${params.chromosomes}" : "",
            params.chr_name_prefix ? "--chr_name_prefix ${params.chr_name_prefix}" : "",
        ].findAll { it }.join(' ')}
    }

    withName: 'gc_map_bias' {
        ext.args = {[
            params.do_gc_correction ? "--do_gc_correction" : "--no_gc_correction",
            params.do_mappability_correction ? "--do_mappability_correction" : "--no_mappability_correction",
            "--gc_position_offset ${params.gc_position_offset}",
            "--map_qual_threshold ${params.map_qual_threshold}",
            "--mappability_length ${params.mappability_length}",
            params.chromosomes ? "--chromosomes ${params.chromosomes}" : "",
            params.chr_name_prefix ? "--chr_name_prefix ${params.chr_name_prefix}" : "",
        ].findAll { it }.join(' ')}
    }

    withName: 'segment_readcount' {
        ext.args = {[
            params.filter_duplicates ? "--filter_duplicates" : "--no_filter_duplicates",
            "--map_qual_threshold ${params.map_qual_threshold}",
        ].join(' ')}
    }

    withName: 'haplotype_allele_readcount' {
        ext.args = {[
            params.filter_duplicates ? "--filter_duplicates" : "--no_filter_duplicates",
            "--map_qual_threshold ${params.map_qual_threshold}",
        ].join(' ')}
    }

    withName: 'create_segments' {
        ext.args = {[
            "--segment_length ${params.segment_length}",
            params.chromosomes ? "--chromosomes ${params.chromosomes}" : "",
            params.chr_name_prefix ? "--chr_name_prefix ${params.chr_name_prefix}" : "",
        ].findAll { it }.join(' ')}
        publishDir = [
            path: { "${params.out_dir}/raw_data" },
            pattern: 'segments.tsv',
            mode: 'copy',
        ]
    }

    withName: 'init_model' {
        ext.args = {[
            "--min_ploidy ${params.min_ploidy}",
            "--max_ploidy ${params.max_ploidy}",
            params.h_normal != null ? "--h_normal ${params.h_normal}" : "",
            params.h_tumour != null ? "--h_tumour ${params.h_tumour}" : "",
            "--tumour_mix_fractions ${params.tumour_mix_fractions}",
            "--divergence_weights ${params.divergence_weights}",
            "--max_copy_number ${params.max_copy_number}",
            "--random_seed ${params.random_seed}",
        ].findAll { it }.join(' ')}
    }

    withName: 'fit_model' {
        ext.args = {[
            params.normal_contamination ? "--normal_contamination" : "--no_normal_contamination",
            "--max_copy_number ${params.max_copy_number}",
            "--likelihood_min_segment_length ${params.likelihood_min_segment_length}",
            "--likelihood_min_proportion_genotyped ${params.likelihood_min_proportion_genotyped}",
            "--num_em_iter ${params.num_em_iter}",
            "--num_update_iter ${params.num_update_iter}",
            params.disable_breakpoints ? "--disable_breakpoints" : "--no_disable_breakpoints",
            params.is_female ? "--is_female" : "--is_male",
            params.do_h_update ? "--do_h_update" : "--no_h_update",
        ].join(' ')}
    }

    withName: 'collate_results' {
        ext.args = {[
            "--max_prop_diverge ${params.max_prop_diverge}",
        ].join(' ')}
        publishDir = [
            path: { "${params.out_dir}" },
            pattern: '*.results.h5',
            mode: 'copy',
            saveAs: { "${it.replace('.results.h5', '.h5')}" },
        ]
    }

    withName: 'merge_seqdata' {
        publishDir = [
            path: { "${params.out_dir}/raw_data/seqdata" },
            pattern: '*.seqdata.h5',
            mode: 'copy',
            saveAs: { "sample_${it.replace('.seqdata.h5', '.h5')}" },
        ]
    }

    withName: 'merge_haps' {
        publishDir = [
            path: { "${params.out_dir}/raw_data" },
            pattern: 'haplotypes.tsv',
            mode: 'copy',
        ]
    }

    withName: 'create_experiment' {
        publishDir = [
            path: { "${params.out_dir}/raw_data/experiment" },
            pattern: '*.experiment.pickle',
            mode: 'copy',
            saveAs: { "sample_${it.replace('.experiment.pickle', '.pickle')}" },
        ]
    }

    withName: 'prepare_readcount_table' {
        publishDir = [
            path: { "${params.out_dir}/raw_data/counts" },
            pattern: '*.counts.tsv',
            mode: 'copy',
            saveAs: { "sample_${it.replace('.counts.tsv', '.tsv')}" },
        ]
    }

    withName: 'ploidy_analysis_plots' {
        publishDir = [
            path: { "${params.out_dir}/raw_data/ploidy_plots" },
            pattern: '*.ploidy_plots.pdf',
            mode: 'copy',
            saveAs: { "sample_${it.replace('.ploidy_plots.pdf', '.pdf')}" },
        ]
    }
}
