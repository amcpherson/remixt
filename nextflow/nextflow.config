params {
    // Required inputs
    ref_data_dir       = null
    raw_data_dir       = null
    breakpoint_file    = null
    config             = null

    // Sample sheet: CSV with columns sample_id, bam_file, type (tumour/normal)
    sample_sheet       = null

    // Alternative to sample sheet: explicit arguments
    tumour_sample_ids  = null
    tumour_bam_files   = null
    results_files      = null
    normal_sample_id   = null
    normal_bam_file    = null
}

process {
    // Default resources
    cpus = 1
    memory = '4 GB'

    withLabel: 'mem_medium' {
        memory = '16 GB'
    }

    withLabel: 'mem_high' {
        memory = '20 GB'
    }

    withLabel: 'mem_very_high' {
        memory = '32 GB'
    }
}

profiles {
    standard {
        process.executor = 'local'
    }

    slurm {
        process.executor = 'slurm'
    }

    sge {
        process.executor = 'sge'
    }
}
